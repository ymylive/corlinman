# corlinman runtime secrets — fill the values, place at repo root as `.env`
#
# These flow into docker/compose/docker-compose.yml via `env_file`.
# `start.sh` resolves any `[providers.*].api_key = { env = "<KEY>" }`
# entries from `config.toml` against this file at boot.

# === LLM providers ==========================================================
# Fill at least one. The provider whose key is non-empty becomes the
# default at first chat unless a model alias points elsewhere.
OPENAI_API_KEY=
# Optional override (default api.openai.com). Useful for OpenAI-compatible
# proxies / local models that speak the OpenAI Chat Completions wire.
# OPENAI_BASE_URL=

GEMINI_API_KEY=
# Optional region override; default is the public Gemini endpoint.
# GEMINI_BASE_URL=

# === QQ channel (NapCat) ====================================================
# napcat container handles the QQ login session. corlinman dials it via
# `CORLINMAN_NAPCAT_URL` + `QQ_WS_URL` set by docker-compose.qq.yml.
# Optional: a comma-separated list of admin QQ ids that can run the
# in-band scan-login + provider-config flow over QQ. Empty = web admin only.
QQ_ADMIN_IDS=

# === Telegram channel =======================================================
# Bot token from @BotFather. Leave empty to skip telegram.
# To activate: paste token here, flip `[channels.telegram] enabled = true`
# in ~/.corlinman/config.toml, restart container.
TELEGRAM_BOT_TOKEN=
# Required only when switching to webhook mode (set `[telegram.webhook]
# public_url`). Any random string ≥ 16 chars. Webhook requests carry it in
# the `X-Telegram-Bot-Api-Secret-Token` header.
TELEGRAM_WEBHOOK_SECRET=

# === Admin web UI auth ======================================================
# Single-shot bootstrap token for the very first login at /admin. Rotate
# from the admin UI after that.
ADMIN_BOOTSTRAP_TOKEN=please-change-me

# === Logging ================================================================
# `info`, `debug`, `warn`. Increase to `debug` while iterating; default
# `info` keeps production logs readable.
RUST_LOG=info
