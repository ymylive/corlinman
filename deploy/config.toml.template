# corlinman runtime config — drop into ~/.corlinman/config.toml on the
# server. The container mounts ~/.corlinman:/data, and start.sh defaults
# CORLINMAN_CONFIG=/data/config.toml.
#
# Per-section docs at /Users/cornna/project/corlinman/docs/config.example.toml
# (the canonical reference). This template is the minimal "QQ + OpenAI/Gemini
# + evolution proposer" verification deploy.

[server]
bind = "0.0.0.0:6005"
data_dir = "/data"

[admin]
# meta_approver_users gates Phase 4 W2 B1 self-improvement proposals.
# Add operator QQ ids that should be able to apply engine-prompt mutations.
meta_approver_users = []
# Bootstrap-token check for the very first /admin login. After that,
# rotate via the admin UI.
bootstrap_token = { env = "ADMIN_BOOTSTRAP_TOKEN" }

# === Providers ==============================================================
# Each `[providers.<name>]` entry has free-form name (the bit after the dot)
# but a CLOSED `kind` value picked from this list:
#   anthropic | openai | google | deepseek | qwen | glm |
#   openai_compatible | mistral | cohere | together | groq |
#   replicate | bedrock | azure
# Unknown kinds break TOML parse → admin/scheduler/channels all fall back.
# OpenAI-compatible 3rd-party clouds (SiliconFlow, OpenRouter, Groq-OpenAI,
# vLLM, Ollama-OpenAI shim, etc.) all use `kind = "openai_compatible"`.

# OpenAI placeholder. The api_key resolves from .env at start.sh time.
# Empty key = provider stays disabled; gateway logs a warn instead of
# erroring so other providers still work.
[providers.openai]
kind = "openai"
api_key = { env = "OPENAI_API_KEY" }
# base_url = ...   # uncomment to point at an OpenAI-compatible proxy

[providers.gemini]
kind = "gemini"
api_key = { env = "GEMINI_API_KEY" }

# SiliconFlow (硅基流动) example — OpenAI-compatible Chinese cloud hosting
# Qwen / GLM / DeepSeek / Yi etc. Same wire as OpenAI, different base_url.
# Uncomment + paste SILICONFLOW_API_KEY into .env to enable.
# [providers.siliconflow]
# kind = "openai_compatible"
# base_url = "https://api.siliconflow.cn/v1"
# api_key = { env = "SILICONFLOW_API_KEY" }

# === Models =================================================================
# Aliases let chat callers ask for `gpt-4o-mini` / `gemini-2.0-flash` etc.
# without binding to a specific provider. The first non-empty provider
# becomes the default.
[models]
default = "gpt-4o-mini"

[models.aliases]
# Free-form alias → (provider, model) lookup
"gpt-4o-mini" = { provider = "openai", model = "gpt-4o-mini" }
"gpt-4o" = { provider = "openai", model = "gpt-4o" }
"gemini-2.0-flash" = { provider = "gemini", model = "gemini-2.0-flash-exp" }
"gemini-2.5-pro" = { provider = "gemini", model = "gemini-2.5-pro-exp-03-25" }

# === Embedding ==============================================================
# Used by the evolution proposer for signal clustering and by RAG /
# episode (D1) for similarity retrieval. Without an embedding provider
# the proposer skips clustering and emits no proposals.
#
# Default: OpenAI text-embedding-3-small (1536-dim). Switch to
# SiliconFlow's Qwen3-Embedding-4B (2560-dim) for higher fidelity:
#   provider = "siliconflow"
#   model = "Qwen/Qwen3-Embedding-4B"
#   dimension = 2560
# (requires the SiliconFlow provider stanza above + `SILICONFLOW_API_KEY` in .env.)
[embedding]
enabled = true
provider = "openai"
model = "text-embedding-3-small"
dimension = 1536

# === Telegram channel (long-poll) ============================================
# Long-poll adapter — no public URL required. Fill TELEGRAM_BOT_TOKEN in .env
# and flip enabled=true to activate. Switch to webhook mode by setting
# `[telegram.webhook].public_url` to your gateway's public HTTPS URL and
# the long-poll adapter steps aside automatically.
[channels.telegram]
enabled = false
bot_token = { env = "TELEGRAM_BOT_TOKEN" }
# Whitelist of chat ids (group or private). Empty = all chats allowed.
allowed_chat_ids = []
# Case-insensitive substring filter for non-mention group messages.
keyword_filter = []
# When true, group messages forwarded only if bot is @-mentioned.
require_mention_in_groups = false

# Webhook mode — set public_url to your gateway's HTTPS URL to switch off
# long-poll. secret_token guards against forged hits via the
# X-Telegram-Bot-Api-Secret-Token header.
[telegram.webhook]
public_url = ""
secret_token = { env = "TELEGRAM_WEBHOOK_SECRET" }
drop_updates_on_reconnect = false

# === QQ channel via NapCat ===================================================
# OneBot v11 forward-WS bridge. NapCat container exposes:
#   :3001 — OneBot WS (this gateway dials it via QQ_WS_URL env)
#   :6099 — webui + scan-login HTTP (admin route dials via CORLINMAN_NAPCAT_URL)
[channels.qq]
enabled = true
# self_ids: this gateway's QQ accounts — populated automatically after
# you scan in via /admin/channels/qq. Listed here for visibility; can
# stay empty until first scan.
self_ids = []
# OneBot v11 endpoint on the in-network napcat container (overridden
# by QQ_WS_URL set in docker-compose.qq.yml).

# Reply rules: respond when @-mentioned in a group, and to all DMs.
[channels.qq.reply]
on_at_mention = true
on_direct_message = true

# === Evolution proposer ======================================================
# Wave 2 self-improvement loop. Default conservative window so the operator
# manually approves every proposal until trust is established.
[evolution]
enabled = true

[evolution.proposer]
# Cron-like; daily at 03:00 server time. Manual trigger via admin UI also OK.
schedule = "0 0 3 * * *"

[evolution.applier]
# auto_apply = false ⇒ every proposal needs operator approval at /admin/evolution
auto_apply = false
# 24h grace window for meta proposals (B1) before auto-rollback gives up
meta_grace_window_hours = 24

[evolution.rollback]
auto_rollback_window_hours = 72

# === Logs ===================================================================
[logs]
level = { env = "RUST_LOG", default = "info" }
file_rotation = "daily"
retention_days = 14

# === Tenants ================================================================
# Single-tenant `default` mode for first-deploy verification. Multi-tenant
# scoping (Phase 3 4-1A) is wired through but stays a single-row config
# until you decide otherwise.
[tenants]
default = "default"
