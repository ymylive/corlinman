    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "lucide-react": "latest",
    "next": "^15.1.0",
    "next-intl": "^3.26.0",
